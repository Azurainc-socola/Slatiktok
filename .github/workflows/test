name: 🚀 Auto Sync 17Track SLA

on:
  workflow_dispatch:

jobs:
  run-sync:
    runs-on: ubuntu-22.04 # Thử đổi sang phiên bản Ubuntu số cụ thể này cho chắc ăn

    steps:
      - name: 📥 Kéo code về máy chủ
        uses: actions/checkout@v4

      - name: 🐍 Cài đặt Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: 📦 Cài thư viện
        run: pip install requests gspread google-auth

      - name: 🏃 Chạy Tool
        env:
          TRACK17_API_KEY: ${{ secrets.TRACK17_API_KEY }}
          SPREADSHEET_ID: ${{ secrets.SPREADSHEET_ID }}
          GCP_JSON: ${{ secrets.GCP_JSON }}
        run: python app.py
